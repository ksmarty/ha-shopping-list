{
  "name": "ha-shopping-list-card",
  "version": "0.1.0",
  "description": "A shopping-style list view for any Home Assistant todo entity, with categories, quantities, sorting, and theming.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "serve": "node dev/serve.mjs",
    "dev": "npm run build && (npm run watch & npm run serve)",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"dev/**/*.{js,mjs,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"dev/**/*.{js,mjs,html}\"",
    "check": "npm run typecheck && npm run format:check",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check",
    "pre-push": "sh scripts/check-dist.sh"
  },
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hacs",
    "shopping-list",
    "card"
  ],
  "author": "MCuello17",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MCuello17/ha-shopping-list.git"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}