# Dependencies
node_modules/

# Build output: we commit the production bundle so HACS can install
# directly from the default branch (Option B during early dev).
# Source maps and other dev-only artifacts stay ignored.
dist/*
!dist/ha-shopping-list-card.js

# TypeScript incremental compile cache
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Env / secrets
.env
.env.*
!.env.example
